{
  "_comment": "Rawso typography standards. See design-system/SKILL.md for usage rules.",
  "fontFamily": {
    "primary": "Inter, system-ui, -apple-system, sans-serif",
    "body": "Inter, system-ui, -apple-system, sans-serif",
    "monospace": "JetBrains Mono, SF Mono, Consolas, monospace"
  },
  "scale": {
    "pageTitle":      { "size": "24px", "weight": "600", "lineHeight": "1.2", "letterSpacing": "-0.025em" },
    "sectionHeading": { "size": "18px", "weight": "600", "lineHeight": "1.3", "letterSpacing": "-0.02em" },
    "cardTitle":      { "size": "16px", "weight": "600", "lineHeight": "1.3", "letterSpacing": "-0.01em" },
    "body":           { "size": "14px", "weight": "400", "lineHeight": "1.5", "letterSpacing": "0" },
    "bodyBold":       { "size": "14px", "weight": "500", "lineHeight": "1.5", "letterSpacing": "0" },
    "label":          { "size": "12px", "weight": "500", "lineHeight": "1.4", "letterSpacing": "0.02em" },
    "small":          { "size": "11px", "weight": "400", "lineHeight": "1.4", "letterSpacing": "0.02em" },
    "kpiLarge":       { "size": "32px", "weight": "700", "lineHeight": "1.1", "letterSpacing": "-0.03em" },
    "kpiMedium":      { "size": "24px", "weight": "700", "lineHeight": "1.1", "letterSpacing": "-0.02em" },
    "kpiLabel":       { "size": "12px", "weight": "400", "lineHeight": "1.4", "letterSpacing": "0.05em" }
  },
  "rules": {
    "tabularNums": "font-variant-numeric: tabular-nums — use on all numeric columns",
    "noAllCaps": "All-caps only for KPI labels and category labels, never for headings",
    "truncate": "Truncate long text with ellipsis, never wrap dashboard card titles",
    "kpiAlignment": "KPI values: right-align or center in container, never left-align"
  }
}
